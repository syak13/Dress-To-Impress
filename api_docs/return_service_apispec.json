{"components":{"schemas":{}},"info":{"description":"Composite microservice for retrieving rental and dress return details, processing returned dress images, and completing returns.","title":"Return Service API","version":"1.0.0"},"openapi":"3.0.2","paths":{"/return/dress/{dress_id}":{"get":{"parameters":[{"example":201,"in":"path","name":"dress_id","required":true,"schema":{"type":"integer"}}],"responses":{"200":{"description":"Dress details retrieved successfully"},"404":{"description":"Dress not found"},"500":{"description":"Failed to reach inventory service"}},"summary":"Get dress details for a return","tags":["Return"]}},"/return/image":{"post":{"requestBody":{"content":{"multipart/form-data":{"schema":{"properties":{"image":{"description":"Image of the returned dress","format":"binary","type":"string"},"rental_id":{"example":1,"type":"integer"},"return_date":{"example":"2026-04-07","format":"date","type":"string"}},"required":["rental_id","image"],"type":"object"}}},"required":true},"responses":{"200":{"description":"Return processed successfully"},"400":{"description":"Missing required fields or invalid/non-dress image"},"404":{"description":"Rental not found"},"500":{"description":"Failed to process return due to downstream service error"}},"summary":"Process a dress return using an uploaded image","tags":["Return"]}},"/return/rental/{rental_id}":{"get":{"parameters":[{"example":1,"in":"path","name":"rental_id","required":true,"schema":{"type":"integer"}}],"responses":{"200":{"description":"Rental details retrieved successfully"},"404":{"description":"Rental not found"},"500":{"description":"Failed to reach rental service"}},"summary":"Get rental details for a return","tags":["Return"]}}}}
