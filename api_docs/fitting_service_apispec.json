{"components":{"schemas":{}},"info":{"description":"Composite microservice for browsing dresses and scheduling or cancelling fitting appointments.","title":"Fitting Service API","version":"1.0.0"},"openapi":"3.0.2","paths":{"/fitting/available":{"get":{"responses":{"200":{"description":"Available dresses retrieved successfully"},"404":{"description":"No available dresses found"},"500":{"description":"Failed to reach inventory service"}},"summary":"Get all available dresses for fitting","tags":["Fitting"]}},"/fitting/cancel/{booking_id}":{"put":{"parameters":[{"example":1,"in":"path","name":"booking_id","required":true,"schema":{"type":"integer"}}],"responses":{"200":{"description":"Fitting appointment cancelled successfully"},"404":{"description":"Booking not found"},"500":{"description":"Booking cancellation failed or downstream service error"}},"summary":"Cancel a fitting appointment","tags":["Fitting"]}},"/fitting/dresses":{"get":{"responses":{"200":{"description":"List of dresses retrieved successfully"},"500":{"description":"Failed to reach inventory service"}},"summary":"Get all dresses for fitting","tags":["Fitting"]}},"/fitting/dresses/{dress_id}":{"get":{"parameters":[{"example":101,"in":"path","name":"dress_id","required":true,"schema":{"type":"integer"}}],"responses":{"200":{"description":"Dress retrieved successfully"},"404":{"description":"Dress not found"},"500":{"description":"Failed to reach inventory service"}},"summary":"Get dress details by dress ID","tags":["Fitting"]}},"/fitting/schedule":{"post":{"requestBody":{"content":{"application/json":{"schema":{"properties":{"customer_id":{"example":1,"type":"integer"},"dress_id":{"example":101,"type":"integer"},"slot_datetime":{"example":"2026-04-12 14:00:00","type":"string"}},"required":["customer_id","dress_id","slot_datetime"],"type":"object"}}},"required":true},"responses":{"201":{"description":"Fitting appointment scheduled successfully"},"400":{"description":"Invalid JSON, missing required fields,